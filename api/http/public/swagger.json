{
    "swagger": "2.0",
    "info": {
        "description": "This is a server for getting crypto currencies",
        "title": "Coin service API",
        "contact": {
            "name": "API Support",
            "email": "romka-sumkin@yandex.ru"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "version": "1.0"
    },
    "host": "localhost:9001",
    "basePath": "/crypto/v1",
    "paths": {
        "/rates": {
            "post": {
                "description": "providing rate info based on short titles of crypto",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "summary": "Get rate info about required titles",
                "parameters": [
                    {
                        "description": "list of required titles",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.TitlesDTO"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.CoinsDTO"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorDTO"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorDTO"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorDTO"
                        }
                    }
                }
            }
        },
        "/rates/aggregated": {
            "post": {
                "description": "providing aggregated rates info based on short titles of crypto",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "summary": "Get aggregated info about requested titles",
                "parameters": [
                    {
                        "description": "list of required titles",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.TitlesDTO"
                        }
                    },
                    {
                        "enum": [
                            "min",
                            "max",
                            "avg"
                        ],
                        "type": "string",
                        "description": "aggregation type: min, max, avg",
                        "name": "agg_type",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.CoinsDTO"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorDTO"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorDTO"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorDTO"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "dto.CoinDTO": {
            "type": "object",
            "properties": {
                "actual_at": {
                    "description": "time when coin cost was actualized\nrequired: false\nexample: 2026-06-09T12:30:00Z",
                    "type": "string"
                },
                "cost": {
                    "description": "coin cost in USD\nrequired: true\nexample: 63097.42",
                    "type": "number"
                },
                "title": {
                    "description": "coin title\nrequired: true\nexample: btc",
                    "type": "string"
                }
            }
        },
        "dto.CoinsDTO": {
            "type": "object",
            "properties": {
                "coins": {
                    "description": "array of coins\nrequired: true\nexample: [{\"title\":\"btc\",\"cost\":63097.42,\"actual_at\":\"2026-06-09T12:30:00Z\"}]",
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/dto.CoinDTO"
                    }
                }
            }
        },
        "dto.ErrorDTO": {
            "type": "object",
            "properties": {
                "message": {
                    "description": "error message\nrequired: true\nexample: titles field is empty",
                    "type": "string"
                },
                "status_code": {
                    "description": "HTTP status code\nrequired: true\nexample: 500",
                    "type": "integer"
                }
            }
        },
        "dto.TitlesDTO": {
            "type": "object",
            "properties": {
                "titles": {
                    "description": "coin titles\nrequired: true",
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "example": [
                        "btc",
                        "eth"
                    ]
                }
            }
        }
    }
}